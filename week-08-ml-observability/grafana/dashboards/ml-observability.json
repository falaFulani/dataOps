{
  "annotations": {
    "list": []
  },
  "description": "Combined operational + ML-specific observability. Two layers, one dashboard.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "⚙️ Operational Metrics (Layer 1 — Your Existing Monitoring)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "req/s",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Request Rate",
      "description": "Total prediction requests per second, broken down by model version",
      "targets": [
        {
          "expr": "rate(prediction_requests_total[1m])",
          "legendFormat": "{{model_version}} — {{predicted_class}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "seconds",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Prediction Latency (p50 / p95 / p99)",
      "description": "Inference latency percentiles — how long the model takes to respond",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Error Rate",
      "description": "Percentage of requests resulting in errors (5xx responses)",
      "targets": [
        {
          "expr": "rate(prediction_requests_total{status=\"error\"}[5m]) / rate(prediction_requests_total[5m])",
          "legendFormat": "error rate"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU Usage" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "Memory Usage" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Resource Usage",
      "description": "Container CPU and memory consumption (standard pod metrics)",
      "targets": [
        {
          "expr": "process_cpu_seconds_total{job=\"model-service\"}",
          "legendFormat": "CPU Usage"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"model-service\"}",
          "legendFormat": "Memory Usage"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "title": "🧠 ML-Specific Metrics (Layer 2 — The New Observability Layer)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 40,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Prediction Distribution",
      "description": "Which classes is the model predicting? A shift here means input data is changing. This is your cheapest drift signal.",
      "targets": [
        {
          "expr": "rate(prediction_requests_total[5m])",
          "legendFormat": "{{predicted_class}}"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Confidence Score Distribution",
      "description": "Histogram of prediction confidence. Dropping confidence = model uncertainty = leading indicator of drift.",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_confidence_bucket[5m]))",
          "legendFormat": "Confidence p50"
        },
        {
          "expr": "histogram_quantile(0.25, rate(prediction_confidence_bucket[5m]))",
          "legendFormat": "Confidence p25"
        },
        {
          "expr": "histogram_quantile(0.10, rate(prediction_confidence_bucket[5m]))",
          "legendFormat": "Confidence p10"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "id": 7,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Model Drift Score",
      "description": "Overall drift score (0=no drift, 1=full drift). Green <0.3, Yellow 0.3-0.5, Orange 0.5-0.7, Red >0.7. Based on statistical tests comparing current input distribution to training distribution.",
      "targets": [
        {
          "expr": "model_drift_score{job=\"model-service\"}",
          "legendFormat": "Drift Score"
        }
      ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "id": 8,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Data Quality Rate",
      "description": "Percentage of incoming prediction requests with valid, complete feature vectors. Below 95% = investigate upstream data pipelines.",
      "targets": [
        {
          "expr": "data_quality_score{job=\"model-service\"}",
          "legendFormat": "Quality Rate"
        }
      ],
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "title": "📊 Feature-Level Drift (Drill-Down)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "OK" } }, "type": "value" },
            { "options": { "1": { "text": "DRIFT" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 19 },
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name"
      },
      "title": "Feature Drift Status",
      "description": "Per-feature drift indicators. Green = stable, Red = drift detected. Tells you exactly which feature pipeline to investigate.",
      "targets": [
        {
          "expr": "feature_drift_detected{job=\"model-service\"}",
          "legendFormat": "{{feature_name}}"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 19 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Data Freshness",
      "description": "How old is the training data vs current time? Stale models degrade silently.",
      "targets": [
        {
          "expr": "time() - model_last_trained_timestamp{job=\"model-service\"}",
          "legendFormat": "Model Age (seconds)"
        },
        {
          "expr": "data_freshness_seconds{job=\"model-service\"}",
          "legendFormat": "Data Freshness"
        }
      ],
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["mlops", "observability", "week-08"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ML Observability — Two Layers",
  "uid": "ml-observability-week08",
  "version": 1
}
